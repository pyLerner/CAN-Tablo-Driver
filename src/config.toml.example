# =============================================================================
# Пример конфигурации: одно табло, секции [display] и [display.N].
# Скопируйте в config.toml и подставьте реальные ID и пути.
# =============================================================================

[can]
channel = "can0"
bitrate = 500000

[iso-tp]
rx_flowcontrol_timeout = 5000
rx_consecutive_frame_timeout = 5000
stmin = 10
blocksize = 8
use_stack_sleep_time = true
loop_sleep_sec = 0.0001

[logs]
dir = "../logs"
file = "tablo.log"
count = 5
max_size = 1048576

[TextIn]
path = "../data/text-in.json"
font = "../data/DejaVuSans.ttf"

[api-server]
host = "0.0.0.0"
port = 8000

# Опционально: явный путь TTF для индекса шрифта 1 (иначе — DejaVuSans-Bold.ttf
# рядом с [TextIn].font, иначе тот же файл, что и font).
# [fonts]
# 1 = "../data/DejaVuSans-Bold.ttf"

[display]
display-id = "front-display"
sender_tx_id = 0x18EF1001
sender_rx_id = 0x18EF1109
width = 192
height = 64

[display.1]
bg = 0
fg = 2
font = 1
text_scale_x = 0.5
area = { x = 0, y = 0, w = 80, h = 64 }
padding = { t = 2, r = 2, b = 2, l = 2 }

[display.2]
bg = 0
fg = 2
font = 1
area = { x = 80, y = 0, w = 112, h = 32 }
padding = { t = 2, r = 2, b = 2, l = 2 }

[display.3]
bg = 0
fg = 2
font = 1
area = { x = 80, y = 32, w = 112, h = 32 }
padding = { t = 2, r = 2, b = 2, l = 2 }

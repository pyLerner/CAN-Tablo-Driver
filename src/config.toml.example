# =============================================================================
# Пример конфигурации драйвера LED-табло (CAN / ISO-TP).
# Скопируйте в config.toml и подставьте реальные ID, пути и размеры.
# Строки, начинающиеся с #, — комментарии и не читаются парсером.
# =============================================================================

# --- CAN-шина (общая для всех табло на одном интерфейсе) -----------------------
[can]
# Имя интерфейса SocketCAN (например vcan0, can0).
channel = "can0"
# Скорость шины, бит/с (должна совпадать с настройкой интерфейса в ОС).
bitrate = 500000
# Пара CAN ID для режима «одно табло» и обратной совместимости с CLI send:
# отправитель → табло (TX) и ответ табло → отправитель (RX), 29-bit.
# Если заданы секции [front-display] и т.д., пары ID дублируются там;
# эти поля используются как источник для [tabloRouteTwoStrings] без отдельных секций.
sender_tx_id = 0x18EF1001
sender_rx_id = 0x18EF1101

# --- ISO-TP (транспорт поверх CAN) --------------------------------------------
[iso-tp]
# Таймаут ожидания Flow Control от приёмника, мс.
rx_flowcontrol_timeout = 5000
# Таймаут между кадрами Consecutive Frame при приёме, мс.
rx_consecutive_frame_timeout = 5000
# STmin для Flow Control (значение в формате, ожидаемом стеком isotp).
stmin = 1
# Размер блока (BS) в Flow Control.
blocksize = 64
# Использовать sleep_time() стека между итерациями process (true) или фикс. паузу.
use_stack_sleep_time = true
# Пауза между итерациями, если use_stack_sleep_time = false (секунды).
loop_sleep_sec = 0.00001

# --- Логи --------------------------------------------------------------------
[logs]
# Каталог для файлов логов (относительно каталога с config.toml или абсолютный).
dir = "../logs"
# Имя основного файла лога.
file = "tablo.log"
# Число ротированных копий при переполнении.
count = 5
# Максимальный размер файла до ротации, байт.
max_size = 1048576

# --- Цвет текста на табло (глобально для рендеринга) --------------------------
[display]
# Имя цвета: BLACK, RED, GREEN, BLUE, YELLOW, CYAN, MAGENTA, WHITE.
color = "YELLOW"

# --- Устаревшая секция одного табло (маршрут + две строки справа) --------------
# Используется CLI «send» и автозаполнение [front-display], если секция front не задана.
[tabloRouteTwoStrings]
# Ширина колонки номера маршрута (логические единицы / пиксели разметки).
route_width = 80
# Горизонтальный масштаб шрифта маршрута (< 1 — сжатие, > 1 — растяжение).
route_text_scale_x = 0.5
# Ширина и высота всей области табло.
width = 192
height = 64
# Внутренние отступы области вывода.
pad_left = 0
pad_right = 0
pad_top = 2
pad_bottom = 2

# --- Входной JSON и шрифт для офлайн-режима send (без HTTP) ------------------
[TextIn]
# Путь к JSON с полями firstString / secondString / thirdString.
path = "../data/text-in.json"
# TTF-шрифт для растеризации текста.
font = "../data/DejaVuSans.ttf"

# --- HTTP API (uvicorn) -------------------------------------------------------
[api-server]
# Адрес привязки: 0.0.0.0 — все интерфейсы; 127.0.0.1 — только localhost.
host = "0.0.0.0"
# TCP-порт сервера REST API.
port = 8000

# =============================================================================
# Ниже — отдельные физические табло (свои пары sender_tx_id / sender_rx_id).
# Секции опциональны: укажите только те табло, что установлены на ТС.
# =============================================================================

# Переднее табло: колонка маршрута слева, справа 1 или 2 строки.
[front-display]
sender_tx_id = 0x18EF1001
sender_rx_id = 0x18EF1101
route_width = 80
route_text_scale_x = 0.5
width = 192
height = 64
pad_left = 0
pad_right = 0
pad_top = 2
pad_bottom = 2
# 1 — одна строка справа от маршрута; 2 — две строки (верх/низ).
right_lines = 2

# Боковое табло (сторона «вперёд по ходу»). Разметка как у переднего.
[side-front-display]
sender_tx_id = 0x18EF2001
sender_rx_id = 0x18EF2101
route_width = 72
route_text_scale_x = 0.5
width = 160
height = 64
pad_left = 0
pad_right = 0
pad_top = 2
pad_bottom = 2
right_lines = 2

# Боковое табло (сторона «назад по ходу»).
[side-rear-display]
sender_tx_id = 0x18EF3001
sender_rx_id = 0x18EF3101
route_width = 72
route_text_scale_x = 0.5
width = 160
height = 64
pad_left = 0
pad_right = 0
pad_top = 2
pad_bottom = 2
right_lines = 1

# Задний маршрутный указатель: всё поле — только номер маршрута (как колонка маршрута).
[rear-display]
sender_tx_id = 0x18EF4001
sender_rx_id = 0x18EF4101
route_text_scale_x = 0.6
width = 128
height = 48
pad_left = 0
pad_right = 0
pad_top = 2
pad_bottom = 2

# Внутрисалонная бегущая строка (без колонки маршрута).
[ticker-board]
sender_tx_id = 0x18EF5001
sender_rx_id = 0x18EF5101
width = 256
height = 32
pad_left = 0
pad_right = 0
pad_top = 2
pad_bottom = 2
# 1 — одна строка на всю ширину; 2 — две горизонтальные полосы.
ticker_lines = 2
